{
  "version": 2,
  "name": "employee-feedback-agent",
  "builds": [
    {
      "src": "frontend/static/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/static/(.*)",
      "dest": "/frontend/static/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/frontend/static/$1"
    }
  ]
}
